{
  "name": "nutrition-daily-report",
  "version": "0.1.1",
  "private": true,
  "description": "Insert a nutrition goal comparison table into the active daily note.",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "preversion": "npm run typecheck && npm test && npm run build",
    "version": "node version-bump.mjs",
    "release": "node release.mjs",
    "release:patch": "npm version patch && node release.mjs",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
